# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# App URL — used server-side to build absolute short URLs and auth redirects.
# MUST be set in production, or server-rendered short URLs fall back to localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Short domain shown in the UI for generated links (e.g. tws.bio)
NEXT_PUBLIC_SHORT_DOMAIN=localhost:3000
